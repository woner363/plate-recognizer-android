<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <!-- 仅 Android 9 (API 28) 及以下导出 CSV 到公共 Downloads 目录需要；
         Android 10+ 走 MediaStore，无需此权限。 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:name=".PlateRecognizerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlateRecognizer">

        <!-- 注意：text-recognition-chinese:16.0.0 是 bundled（模型打包进 APK），
             不需要 com.google.mlkit.vision.DEPENDENCIES meta-data；那条 meta-data
             仅适用于通过 Play Services 拉取模型的 unbundled 依赖。 -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.PlateRecognizer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
